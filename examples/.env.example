# GitHub Authentication
# Option 1: Personal Access Token
GITHUB_TOKEN=ghp_your_token_here

# Option 2: GitHub App
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook Secret (for webhook server)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitLab (if using GitLab provider)
# GITLAB_TOKEN=glpat-your_token_here

# Azure DevOps (if using Azure DevOps provider)
# AZDO_TOKEN=your_azdo_pat_here

# Optional: Config file path override
# PR_AI_REVIEWER_CONFIG=./pr-ai-reviewer.config.yaml

# Optional: Logging
# LOG_LEVEL=info
# NODE_ENV=production
