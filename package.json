{
  "name": "pr-ai-reviewer",
  "version": "1.0.0",
  "description": "Production-grade AI-powered code review tool for pull requests",
  "main": "dist/index.js",
  "bin": {
    "pr-ai-reviewer": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node dist/cli/index.js",
    "webhook": "ts-node src/cli/index.ts serve-webhooks"
  },
  "keywords": [
    "code-review",
    "ai",
    "pull-request",
    "llm",
    "ollama",
    "github",
    "gitlab",
    "azure-devops"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@octokit/auth-app": "^6.0.3",
    "@octokit/rest": "^20.0.2",
    "@octokit/webhooks": "^12.0.10",
    "axios": "^1.6.5",
    "commander": "^11.1.0",
    "diff-parse": "^0.0.13",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "minimatch": "^9.0.3",
    "parse-diff": "^0.11.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "sqlite3": "^5.1.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
